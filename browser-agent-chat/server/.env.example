# Required for Magnitude agent
# (Not needed if using claude-code provider with OAuth)
# ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Credential encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CREDENTIALS_ENCRYPTION_KEY=

# Redis (required for session persistence)
REDIS_URL=redis://localhost:6379
SESSION_TTL_SECONDS=600

# Browser Manager
# CDP_PORT_START=19300
# CDP_PORT_RANGE=100
# WARM_BROWSERS=1
# HEADLESS=true

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5174
